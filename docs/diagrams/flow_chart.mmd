flowchart TD
    %% Manual Summary (US1) - Full-Stack Flow Chart

    A([User clicks Generate Summary]) --> B[Open ManualSummary modal]
    B --> C[User selects time range preset]
    C --> D[Frontend calls apiService.generateManualSummary]

    D --> E[POST /api/summaries/manual<br/>channelId, hours, maxMessages]
    E --> F{JWT valid?}
    F -->|No| G[401 Unauthorized]
    F -->|Yes| H{channelId or dmId<br/>provided correctly?}
    H -->|No| I[400 Bad Request]
    H -->|Yes| J{User has access<br/>to channel/DM?}
    J -->|No| K[403 Forbidden]

    J -->|Yes| L[SummaryService.generateManualSummary]
    L --> M[Fetch messages from PostgreSQL<br/>WHERE timestamp >= since LIMIT max]
    M --> N{Messages found?}
    N -->|No| O[Return empty summary]
    N -->|Yes| P[SummarizationProvider.summarize]
    P --> Q[Extract key topics via word frequency]
    Q --> R[Build overview text]
    R --> S[Identify important messages]
    S --> T[Compute stats: totalMessages, uniqueUsers, questions, decisions]
    T --> U[Assemble SummaryData object]

    U --> V[200 JSON response]
    O --> V
    V --> W[Frontend receives summaryData]
    W --> X[Display summary in modal]

    X --> Y{User changes time range?}
    Y -->|Yes| C
    Y -->|No| Z([User closes modal])

    G --> AA([Error displayed to user])
    I --> AA
    K --> AA

    classDef start fill:#e3f2fd,stroke:#1a73e8,stroke-width:2px
    classDef frontend fill:#e8f5e9,stroke:#34a853,stroke-width:2px
    classDef backend fill:#fff3e0,stroke:#e65100,stroke-width:2px
    classDef error fill:#fce8e6,stroke:#d93025,stroke-width:2px
    classDef decision fill:#f3e5f5,stroke:#4a148c,stroke-width:2px

    class A,Z,AA start
    class B,C,D,W,X frontend
    class E,L,M,P,Q,R,S,T,U,V,O backend
    class F,H,J,N,Y decision
    class G,I,K error
