graph TB
    %% Manual Summary (US1) - Full-Stack Architecture Diagram

    subgraph "Frontend (React)"
        A[MessageArea Component]
        B[ManualSummary Component<br/>Modal · Time Presets · Display]
        C[apiService.generateManualSummary]
    end

    subgraph "Backend (Express.js)"
        D[POST /api/summaries/manual<br/>Summary Route]
        E[Auth Middleware<br/>JWT Verification]
        F[Channel.hasAccess / DM Check<br/>Access Control]
        G[SummaryService.generateManualSummary<br/>Orchestration]
        H[SummarizationProvider.summarize<br/>Mocked LLM]
    end

    subgraph "Data Layer"
        I[(PostgreSQL<br/>messages · users)]
    end

    %% Flow
    A -->|user clicks Generate Summary| B
    B -->|POST with channelId, hours| C
    C -->|HTTP| D
    D --> E
    E --> F
    F --> G
    G -->|fetch messages since timestamp| I
    G -->|messages + authorMap| H
    H -->|overview, keyTopics, stats| G
    G -->|SummaryData| D
    D -->|JSON response| C
    C -->|summaryData| B

    classDef frontend fill:#e3f2fd,stroke:#1a73e8,stroke-width:2px
    classDef backend fill:#e8f5e9,stroke:#34a853,stroke-width:2px
    classDef data fill:#fff3e0,stroke:#e65100,stroke-width:2px

    class A,B,C frontend
    class D,E,F,G,H backend
    class I data
