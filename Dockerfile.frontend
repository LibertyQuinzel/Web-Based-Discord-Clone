# Frontend Dockerfile
FROM node:20-alpine

WORKDIR /app

# Copy package files
COPY package*.json ./
COPY pnpm-lock.yaml* ./

# Install dependencies
RUN npm install

# Copy source code (excluding node_modules)
COPY src ./src/
COPY index.html ./
COPY vite.config.ts ./
COPY postcss.config.mjs ./

# Expose port
EXPOSE 5173

# Start development server
CMD ["npm", "run", "dev"]
