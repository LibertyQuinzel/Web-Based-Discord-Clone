# Frontend Dockerfile
FROM node:20-alpine

WORKDIR /app

# Copy package files
COPY package*.json ./
COPY pnpm-lock.yaml* ./

# Install pnpm and dependencies
RUN npm install -g pnpm
RUN pnpm install

# Copy source code (excluding node_modules)
COPY src ./src/
COPY index.html ./
COPY vite.config.ts ./
COPY postcss.config.mjs ./

# Expose port
EXPOSE 5173

# Start development server
CMD ["pnpm", "dev", "--", "--host", "0.0.0.0", "--port", "5173", "--strictPort"]
